<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F8F6">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TOP BAR -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌿 Sahyadri Siri"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:textColor="#145A32"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sacred Water Monitoring"
                    android:textSize="14sp"
                    android:textColor="#4E944F"/>
            </LinearLayout>

        </LinearLayout>

        <!-- HERO CARD -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1B5E20"
                android:padding="22dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LIVE WATER NETWORK"
                    android:textStyle="bold"
                    android:textColor="#C8E6C9"
                    android:textSize="12sp"
                    android:padding="8dp"
                    android:background="#2E7D32"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Protecting Sacred&#10;Water Streams"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="24dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Monitor rivers, springs and water bodies across the Western Ghats."
                    android:textColor="#E8F5E9"
                    android:textSize="15sp"
                    android:layout_marginTop="14dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="28dp">

                    <!-- MAP BUTTON -->

                    <Button
                        android:id="@+id/btnMap"
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_weight="1"
                        android:text="🗺 Explore Map"
                        android:textStyle="bold"
                        android:textColor="#1B5E20"
                        android:backgroundTint="#FFFFFF"
                        android:clickable="true"
                        android:focusable="true"/>

                    <Space
                        android:layout_width="12dp"
                        android:layout_height="wrap_content"/>

                    <!-- REPORT BUTTON -->

                    <Button
                        android:id="@+id/btnReport"
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_weight="1"
                        android:text="📝 Report"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#43A047"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- QUICK ACTIONS -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quick Actions"
            android:textStyle="bold"
            android:textSize="22sp"
            android:textColor="#1B5E20"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="18dp"/>

        <!-- VIEW REPORTS CARD -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="120dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="5dp"
            android:layout_marginBottom="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:gravity="center"
                    android:text="📋"
                    android:textSize="28sp"
                    android:background="#E3F2FD"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View Water Reports"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:textColor="#0D47A1"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Check all community submissions and reports."
                        android:textColor="#616161"
                        android:textSize="14sp"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btnView"
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:text="Open"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#1565C0"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- IMPACT SECTION -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Community Impact"
            android:textStyle="bold"
            android:textSize="22sp"
            android:textColor="#1B5E20"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- REPORT CARD -->

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_weight="1"
                app:cardCornerRadius="20dp"
                app:cardElevation="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="#FFFFFF">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💧"
                        android:textSize="32sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Live Reports"
                        android:textStyle="bold"
                        android:textColor="#1565C0"
                        android:textSize="18sp"
                        android:layout_marginTop="10dp"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <Space
                android:layout_width="16dp"
                android:layout_height="wrap_content"/>

            <!-- MAP CARD -->

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_weight="1"
                app:cardCornerRadius="20dp"
                app:cardElevation="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="#FFFFFF">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌍"
                        android:textSize="32sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dynamic Maps"
                        android:textStyle="bold"
                        android:textColor="#2E7D32"
                        android:textSize="18sp"
                        android:layout_marginTop="10dp"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- FOOTER -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Together for cleaner rivers 🌿"
            android:textStyle="italic"
            android:textColor="#558B2F"
            android:textSize="16sp"
            android:layout_gravity="center"
            android:layout_marginTop="34dp"
            android:layout_marginBottom="20dp"/>

    </LinearLayout>

</ScrollView>