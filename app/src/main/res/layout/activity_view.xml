<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F8F6">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TITLE -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋 Water Reports"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#145A32"
            android:layout_marginTop="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Community water monitoring records."
            android:textSize="15sp"
            android:textColor="#4E944F"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="24dp"/>

        <!-- REPORTS CARD -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="#FFFFFF">

                <!-- REPORT CONTAINER -->

                <LinearLayout
                    android:id="@+id/reportsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

                <!-- CLEAR BUTTON -->

                <Button
                    android:id="@+id/clearBtn"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:text="Clear All Reports"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#C62828"
                    android:layout_marginTop="28dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- FOOTER -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Protect every drop 💧"
            android:textStyle="italic"
            android:textColor="#558B2F"
            android:textSize="15sp"
            android:layout_gravity="center"
            android:layout_marginTop="28dp"/>

    </LinearLayout>

</ScrollView>